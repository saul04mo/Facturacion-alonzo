rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════
    // Helper functions
    // ════════════════════════════════════════
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'administrador';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isOwnerOrAdmin(uid) {
      return isOwner(uid) || isAdmin();
    }

    // App/Web sales use sellerUid = 'APP' or 'WEB'
    function isAppOrWebSale() {
      return request.resource.data.sellerUid in ['APP', 'WEB'];
    }

    // ════════════════════════════════════════
    // 1. CONFIG (exchange rate, counters)
    // ════════════════════════════════════════
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAuth(); // counter updated via transaction
    }

    // ════════════════════════════════════════
    // 1b. EXCHANGE RATE HISTORY (append-only log)
    // ════════════════════════════════════════
    // Cada vez que se actualiza la tasa BCV en /config/exchangeRate,
    // se escribe un doc aquí con previousRate, newRate, change, source,
    // updatedBy, userName, timestamp. Append-only: ningún usuario puede
    // editar ni borrar entradas históricas.
    match /exchangeRateHistory/{entryId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ════════════════════════════════════════
    // 2. PRODUCTS
    // ════════════════════════════════════════
    match /products/{productId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAuth(); // sellers update stock via sales
    }

    // ════════════════════════════════════════
    // 3. CLIENTS
    // ════════════════════════════════════════
    match /clients/{clientId} {
      // Anyone auth can read (needed for RIF lookup)
      allow read: if isAuth();
      // Users can create/update ONLY their own doc
      allow create: if isOwner(clientId) || isAdmin();
      allow update: if isOwner(clientId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════
    // 4. INVOICES
    // ════════════════════════════════════════
    match /invoices/{invoiceId} {
      // Auth users can read their own invoices or admins read all
      allow read: if isAuth();

      // Create: POS sellers (sellerUid == auth.uid) OR App/Web (sellerUid == 'APP'/'WEB')
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['numericId', 'items', 'total', 'date', 'status'])
        && request.resource.data.total >= 0
        && request.resource.data.items.size() > 0
        && (
          request.resource.data.sellerUid == request.auth.uid  // POS seller
          || isAppOrWebSale()                                   // App/Web sale
        );

      // Update: auth users (for status changes, payments, linking)
      allow update: if isAuth();

      // Never delete invoices
      allow delete: if false;
    }

    // ════════════════════════════════════════
    // 5. COUPONS
    // ════════════════════════════════════════
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      // Auth users can update (usedCount increment, usageByClient)
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['usedCount', 'usageByClient']);
    }

    // ════════════════════════════════════════
    // 6. PROMOTIONS
    // ════════════════════════════════════════
    match /promotions/{promotionId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 7. WISHLISTS
    // ════════════════════════════════════════
    match /wishlists/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ════════════════════════════════════════
    // 8. USERS (POS staff)
    // ════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwnerOrAdmin(userId);
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 9. EMPLOYEES / PAYROLL
    // ════════════════════════════════════════
    // NOTA: los nombres en snake_case (employee_incidents, payroll_periods,
    // payroll_receipts) coinciden con la nomenclatura que usa el código
    // en src/. Cualquier rule con camelCase causaría permission-denied
    // al caer en el catch-all final.
    match /employees/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /payroll_periods/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /payroll_receipts/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /employee_incidents/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 10. BANNERS (home carousel)
    // ════════════════════════════════════════
    match /banners/{bannerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 11. ANNOUNCEMENTS (top bar marquee)
    // ════════════════════════════════════════
    // Mensajes que rotan en la barra negra superior de la web.
    // Read es PÚBLICO porque la tienda web los muestra a visitantes
    // anónimos. Solo admins pueden crear/editar/borrar.
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 12. INVENTORY TRANSFERS (Almacén ↔ Tienda)
    // ════════════════════════════════════════
    // Órdenes de transferencia de stock entre sucursales.
    // Flujo: pending → in_transit → received (o cancelled).
    // Cualquier usuario autenticado puede leer y crear/actualizar.
    // No permitimos delete — las transferencias son auditables, si
    // hay un error la solución es marcarlas como 'cancelled' con
    // motivo, no borrarlas.
    match /inventoryTransfers/{transferId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ════════════════════════════════════════
    // DENY EVERYTHING ELSE
    // ════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
